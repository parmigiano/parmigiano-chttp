    "/users/me/avatar": {
      "patch": {
        "summary": "Uploading a users avatar",
        "description": "Updates the current users avatar via a file",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "X-Debug",
            "in": "header",
            "description": "Enabled dev mode (example skip PoW security)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Response language from the server (in which language the client is)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "en"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "image/jpeg": {
              "schema": {
                "type": "string",
                "format": "binary"
              },
              "description": "Upload a JPEG avatar"
            },
            "image/png": {
              "schema": {
                "type": "string",
                "format": "binary"
              },
              "description": "Upload a PNG avatar"
            }
          }
        },
        "responses": {
          "200": {
            "description": "Avatar uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "https://s3.example.com/avatar/123.png"
                    }
                  },
                  "required": ["message"]
                }
              }
            }
          },
          "400": {
            "description": "Request error or duplicate",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "There is no data to process"
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Couldn't save the file"
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          }
        }
      }
    },
