    "/groups": {
      "post": {
        "summary": "Create a chat group",
        "description": "Creates a new chat group for the authenticated user and adds chats to it.",
        "tags": ["Groups"],
        "parameters": [
          {
            "name": "X-Debug",
            "in": "header",
            "description": "Enabled dev mode (example skip PoW security)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Response language from the server (in which language the client is)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "en"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "chat_ids"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the group (max 20 chars)",
                    "maxLength": 20
                  },
                  "chat_ids": {
                    "type": "array",
                    "description": "Array of chat IDs to add to the group",
                    "items": {
                      "type": "integer",
                      "format": "int64"
                    },
                    "maxItems": 65
                  }
                }
              },
              "example": {
                "name": "My Chat Group",
                "chat_ids": [101, 102, 103]
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Group created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "format": "int64",
                      "description": "Group ID"
                    },
                    "name": {
                      "type": "string",
                      "description": "Group name"
                    },
                    "chat_ids": {
                      "type": "array",
                      "items": {
                        "type": "integer",
                        "format": "int64"
                      },
                      "description": "Array of chat IDs added to the group"
                    }
                  }
                },
                "example": {
                  "id": 123,
                  "name": "My Chat Group",
                  "chat_ids": [101, 102, 103]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AuthLogin": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 5,
            "maxLength": 254
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 16
          }
        }
      },
      "AuthCreate": {
        "type": "object",
        "required": ["name", "username", "email"],
        "properties": {
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "AuthConfirmEmail": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "AuthVerify": {
        "type": "object",
        "required": ["email", "code"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "code": {
            "type": "integer",
            "example": 123456
          }
        }
      },
      "CreateChat": {
        "type": "object",
        "required": ["title", "chat_type"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 30
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "chat_type": {
            "type": "string",
            "minLength": 4,
            "maxLength": 255
          }
        }
      },
      "UserUpdateProfile": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 4,
            "maxLength": 24,
            "example": "john_doe"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 24,
            "example": "John"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "minLength": 8,
            "maxLength": 254,
            "example": "+123456789012"
          },
          "overview": {
            "type": "string",
            "minLength": 1,
            "maxLength": 125,
            "example": "Short description"
          },
          "username_visible": {
            "type": "boolean",
            "example": true
          },
          "phone_visible": {
            "type": "boolean",
            "example": false
          },
          "email_visible": {
            "type": "boolean",
            "example": true
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 255,
            "example": "strongpassword123"
          }
        }
      },
      "ChatPreview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64",
            "example": 123
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "username": {
            "type": "string",
            "example": "johndoe"
          },
          "avatar": {
            "type": "string",
            "example": "https://cdn.example.com/avatar.jpg",
            "nullable": true
          },
          "user_uid": {
            "type": "integer",
            "format": "uint64",
            "example": 987654321
          },
          "last_message": {
            "type": "string",
            "example": "Hey, how are you?"
          },
          "last_message_date": {
            "type": "integer",
            "description": "Unix timestamp",
            "example": 1706323123
          },
          "unread_message_count": {
            "type": "integer",
            "example": 3
          }
        }
      },
      "ChatsHistoryResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatPreview"
            }
          }
        }
      },
      "ChatSetting": {
        "type": "object",
        "required": ["name", "username", "email"],
        "properties": {
          "message": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "format": "uint64",
                "example": 1
              },
              "created_at": {
                "type": "integer",
                "format": "int64",
                "description": "Unix timestamp",
                "example": 1700000000
              },
              "updated_at": {
                "type": "integer",
                "format": "int64",
                "description": "Unix timestamp",
                "example": 1700001000
              },
              "chat_id": {
                "type": "integer",
                "format": "uint64",
                "example": 123
              },
              "custom_background": {
                "type": "string",
                "example": "#ffffff"
              },
              "blocked": {
                "type": "boolean",
                "example": false
              },
              "who_blocked_uid": {
                "type": "integer",
                "format": "uint64",
                "example": 0,
                "description": "User UID who blocked the chat (0 if not blocked)"
              }
            },
            "required": [
              "id",
              "created_at",
              "updated_at",
              "chat_id",
              "blocked",
              "who_blocked_uid"
            ]
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "created_at": { "type": "integer", "format": "int64" },
          "user_uid": { "type": "integer", "format": "int64" },
          "avatar": { "type": "string", "nullable": true },
          "name": { "type": "string", "nullable": true },
          "username": { "type": "string", "nullable": true },
          "username_visible": { "type": "boolean" },
          "email": { "type": "string", "format": "email", "nullable": true },
          "email_visible": { "type": "boolean" },
          "email_confirm": { "type": "boolean" },
          "phone": { "type": "string", "nullable": true },
          "phone_visible": { "type": "boolean" },
          "overview": { "type": "string", "nullable": true }
        },
        "required": ["id", "created_at", "user_uid"]
      },
      "UserInfoResponse": {
        "type": "object",
        "properties": {
          "message": { "$ref": "#/components/schemas/UserInfo" }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "ChatTranslate": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 0,
            "maxLength": 3000
          }
        }
      },
      "ChatBotAi": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "message": {
            "type": "string",
            "minLength": 0,
            "maxLength": 3000
          }
        }
      }
    }
  }
}